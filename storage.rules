rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /listings/{listingId}/{imageFile} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /listing_images/{imageFile} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
